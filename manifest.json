{
	"manifest_version": 3,
	"name": "AI Article Summarizer",
	"version": "1.0",
	"version_name": "1.0.0",
	"description": "Summarize any article with your Google Gemini API key. Choose between brief, detailed, or bullet point summaries.",

	"permissions": ["activeTab", "storage"],

	"icons": {
		"16": "icon.png",
		"48": "icon.png",
		"128": "icon.png",
		"512": "icon.png"
	},

	"action": {
		"default_popup": "src/popup/popup.html",
		"default_icon": {
			"16": "icon.png",
			"48": "icon.png",
			"128": "icon.png"
		}
	},

	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["src/content.js"]
		}
	],

	"background": {
		"service_worker": "src/background.js"
	},

	"options_page": "src/options/options.html",

	"host_permissions": ["https://generativelanguage.googleapis.com/*"]
}
